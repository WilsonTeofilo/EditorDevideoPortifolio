// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

model VideoStats {
  id        String   @id // YouTube Video ID
  title     String
  views     Int
  likes     Int
  updatedAt DateTime @updatedAt
}

model CacheMetadata {
  key       String   @id // e.g. "youtube_totals"
  value     String
  updatedAt DateTime @updatedAt
}
